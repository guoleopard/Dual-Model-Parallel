{
  "name": "dfiia-multi-chat",
  "version": "1.0.0",
  "description": "Dual AI Chat - Gemini & ChatGPT side by side",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.dfiia.multichat",
    "productName": "DualAIChat",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "publish": null
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "asar": true
  },
  "keywords": [
    "electron",
    "gemini",
    "chatgpt",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
